# =============================================================================
# aigp-mlops-hub — Environment Configuration Template
# Copy to config.env and fill in values before running any setup scripts.
# config.env is gitignored — never commit real credentials.
#
# AIGP BoK: Domain IV — Responsible AI Implementation
# EU AI Act: Art. 9 (Risk Management), Art. 10 (Data Governance)
# =============================================================================

# -----------------------------------------------------------------------------
# JFrog Platform
# AIGP: Domain III — Supply chain traceability begins here
# EU AI Act: Art. 10 — Data governance requires knowing where artifacts live
# -----------------------------------------------------------------------------
JPD_URL="https://tsmemea.jfrog.io"
JF_ADMIN_TOKEN="your-jfrog-identity-token"   # Admin token — needs manage permissions on platform
PROJECT_KEY="aigp-demo"

# -----------------------------------------------------------------------------
# TO RUN AGAINST A DIFFERENT JPD — change only these 3 values:
# JPD_URL, JF_ADMIN_TOKEN, PROJECT_KEY
# Everything else auto-derives from these.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Artifactory Repositories (created by 00_platform_setup.sh)
# EU AI Act: Art. 10 — Segregated repos enforce data governance boundaries
# -----------------------------------------------------------------------------
ML_LOCAL_REPO="aigp-demo-ml-local"
ML_REMOTE_REPO="aigp-demo-ml-remote"
ML_VIRTUAL_REPO="aigp-demo-ml-virtual"
DOCKER_LOCAL_REPO="aigp-demo-docker-local"
DOCKER_REMOTE_REPO="aigp-demo-docker-remote"
DOCKER_VIRTUAL_REPO="aigp-demo-docker-virtual"
HF_PROXY="${JPD_URL}/artifactory/api/huggingfaceml/${ML_REMOTE_REPO}"

# -----------------------------------------------------------------------------
# AppTrust Application
# AIGP: Domain IV — Conformity assessment requires a registered application
# EU AI Act: Art. 9 — Risk management system tied to a versioned application
# -----------------------------------------------------------------------------
APPLICATION_KEY="aigp-devops-helper-llm"
APP_VERSION="2.1.5"
STAGE_DEV="aigp-demo-DEV"
STAGE_QA="aigp-demo-QA"
STAGE_PROD="PROD"

# -----------------------------------------------------------------------------
# Evidence Signing Keys
# AIGP: Domain III — Cryptographic provenance is non-repudiable evidence
# EU AI Act: Art. 12 — Record-keeping requires tamper-evident audit trail
# -----------------------------------------------------------------------------
EVIDENCE_KEY_ALIAS="aigp-Evidence-Key"
# EVIDENCE_PRIVATE_KEY — raw PEM string, set as GitHub secret (not here)

# -----------------------------------------------------------------------------
# GitHub OIDC
# AIGP: Domain IV — Secure-by-design CI reduces credential exposure risk
# -----------------------------------------------------------------------------
OIDC_PROVIDER_NAME="aigp-hub-github"
GITHUB_REPO="eliajfrog/aigp-mlops-hub"

# -----------------------------------------------------------------------------
# Model Configuration
# AIGP: Domain III — Model identity must be pinned for reproducibility
# EU AI Act: Art. 13 — Transparency requires disclosed model identity
# -----------------------------------------------------------------------------
MODEL_ID="devops_helper_elia_v2"
BASE_MODEL="Qwen/Qwen1.5-0.5B-Chat"
MODEL_SERVING_ENDPOINT="https://a0kcaohwpdorq.ml.jfrog.io/v1/devops_helper_elia_v2/predict"

# -----------------------------------------------------------------------------
# Xray Policy / Watch
# AIGP: Domain III — Continuous vulnerability scanning (TEVV)
# EU AI Act: Art. 15 — Cybersecurity requirements for high-risk AI
# -----------------------------------------------------------------------------
XRAY_POLICY_NAME="aigp-critical-cve-policy"
XRAY_WATCH_NAME="aigp-model-watch"
